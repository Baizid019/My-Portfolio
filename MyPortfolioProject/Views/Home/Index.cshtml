@section Scripts {
    <script>
        function scrollGallery(scrollOffset) {
            const gallery = document.getElementById('featuredGallery');
            if (gallery) {
                gallery.scrollLeft += scrollOffset;
            }
        }

        function scrollProjects(direction) {
            const projectSlider = document.getElementById('projectSlider');
            if (projectSlider) {
                // Find the first project card item to calculate exact scrolling width dynamically
                const firstCard = projectSlider.querySelector('.col-12');
                if (firstCard) {
                    const cardWidth = firstCard.offsetWidth;
                    // Multiply cardWidth by direction (1 for right, -1 for left)
                    projectSlider.scrollLeft += (cardWidth * direction);
                } else {
                    // Fallback default step if card isn't found
                    projectSlider.scrollLeft += (360 * direction);
                }
            }
        }
    </script>
}