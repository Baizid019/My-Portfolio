@{
    ViewData["Title"] = "Home - Portfolio";
}
<style>
    /* --- SYSTEM CORE LAYOUT & BACKGROUNDS --- */
    :root {
        --primary-gradient: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
        --light-bg-top: #f3f0ff;
        --light-bg-bottom: #eef2f6;
        --text-main: #1e293b;
    }

    body {
        background: linear-gradient(180deg, var(--light-bg-top) 0%, var(--light-bg-bottom) 100%);
        background-attachment: fixed;
        color: var(--text-main);
        font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
        min-height: 100vh;
    }

    .text-gradient {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* --- BEAUTIFIED NEO-BRUTALISM NAVBAR --- */
    .custom-nav-link {
        background-color: #ffffff;
        color: #000000 !important;
        border: 2px solid #000000;
        border-radius: 8px;
        box-shadow: 2px 2px 0px #000000;
        transition: all 0.2s ease;
        font-weight: 700 !important;
    }

        .custom-nav-link:hover {
            transform: translate(1px, 1px);
            box-shadow: 1px 1px 0px #000000;
            background-color: #f8f7ff;
        }

    .nav-item {
        margin-left: 12px;
    }

    /* --- MAIN PORTFOLIO CARD STYLING --- */
    .portfolio-card {
        background: #ffffff;
        border: 2px solid #000000;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .portfolio-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(124, 58, 237, 0.12);
        }

    /* --- ULTRALUXE TECH-TERMINAL PROFILE COMPONENT (NEW) --- */
    .developer-terminal-window {
        position: relative;
        width: 340px;
        max-width: 100%;
        background: #1e1e2e;
        border: 3px solid #000000;
        border-radius: 16px;
        box-shadow: 8px 8px 0px #000000;
        margin: 30px auto;
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .terminal-top-bar {
        background: #ffffff;
        border-bottom: 3px solid #000000;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .terminal-dots {
        display: flex;
        gap: 6px;
    }

    .dot-mac {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 1.5px solid #000000;
    }

        .dot-mac.red {
            background-color: #ff5f56;
        }

        .dot-mac.yellow {
            background-color: #ffbd2e;
        }

        .dot-mac.green {
            background-color: #27c93f;
        }

    .terminal-title {
        font-family: 'Courier New', Courier, monospace;
        font-weight: 800;
        color: #000000;
        font-size: 0.9rem;
    }

    .terminal-badge {
        font-size: 0.7rem;
        font-weight: 800;
        background: var(--primary-gradient);
        color: #ffffff;
        padding: 2px 8px;
        border: 1.5px solid #000000;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .terminal-body-content {
        position: relative;
        width: 100%;
        background-color: #2e2e3e;
        line-height: 0;
        overflow: hidden;
    }

    .terminal-profile-img {
        width: 100%;
        height: auto;
        object-fit: cover;
        transition: transform 0.5s cubic-bezier(0.15, 0.85, 0.45, 1), filter 0.3s ease;
        filter: grayscale(15%) contrast(105%);
    }

    /* Terminal Hover Physics */
    .developer-terminal-window:hover {
        transform: translate(-4px, -4px) rotate(-1deg);
        box-shadow: 14px 14px 0px #000000;
    }

        .developer-terminal-window:hover .terminal-profile-img {
            transform: scale(1.04);
            filter: grayscale(0%) contrast(100%);
        }

        .developer-terminal-window:hover .terminal-badge {
            animation: pulseLive 1s infinite alternate;
        }

    @@keyframes pulseLive {
        0% {
            opacity: 0.7;
        }

        100% {
            opacity: 1;
            transform: scale(1.05);
        }
    }

    /* --- PREMIUM BRANDED SECTION TITLE COMPONENT --- */
    .neo-section-header {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        padding-bottom: 8px;
    }

    .neo-header-tag {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 1px;
        background: #000000;
        color: #ffffff;
        padding: 4px 10px;
        border-radius: 6px;
        margin-bottom: 12px;
        box-shadow: 2px 2px 0px var(--text-main);
    }

    .header-separator {
        color: #000000;
        margin: 0 6px;
        font-weight: 300;
        opacity: 0.4;
    }

    .section-title {
        font-weight: 800;
        color: #000000;
    }

    /* --- SKILLS & ACCENT BADGES --- */
    .badge-custom {
        background: rgba(124, 58, 237, 0.08);
        color: #7c3aed;
        border: 1.5px solid #000000;
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .skill-pill {
        background-color: #ffffff;
        border: 1.5px solid #000000;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e293b;
        display: inline-block;
        transition: all 0.2s ease;
    }

        .skill-pill:hover {
            background: var(--primary-gradient);
            color: #ffffff !important;
            border-color: #7c3aed;
            transform: scale(1.05);
        }

    .skill-category-card {
        background: #fafafa;
        border: 2px solid #000000;
        border-radius: 16px;
        padding: 20px;
        height: 100%;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .skill-category-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 0px #000000;
            background-color: #fdfcff;
        }

    /* --- TIMELINES & WORK EXPERIENCE --- */
    .timeline-item {
        border-left: 3px solid #000000;
        padding-left: 24px;
        position: relative;
    }

        .timeline-item::before {
            content: '';
            position: absolute;
            width: 15px;
            height: 15px;
            background: #7c3aed;
            border: 2px solid #000000;
            border-radius: 50%;
            left: -9px;
            top: 14px;
        }

    /* --- BUTTONS & TIMELINE LOGOS --- */
    .btn-download-custom {
        background-color: #f3f0ff;
        color: #7c3aed;
        border: 2.5px solid #000000;
        border-radius: 14px;
        font-weight: 800;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 0px #000000;
        transition: all 0.2s ease;
    }

        .btn-download-custom:hover {
            background-color: #e8e3ff;
            color: #6d28d9;
            transform: translate(1px, 1px);
            box-shadow: 1px 1px 0px #000000 !important;
        }

        .btn-download-custom:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0px #000000;
        }

    .institution-logo-container {
        width: 50px;
        height: 50px;
        min-width: 50px;
        border: 2px solid #000000;
        border-radius: 12px;
        overflow: hidden;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .institution-logo-container img {
            width: 85%;
            height: 85%;
            object-fit: contain;
        }

    .tech-logo-box {
        border: 2px solid #000000;
        border-radius: 14px;
        background-color: #ffffff;
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100px;
        box-shadow: 0 4px 0px #000000;
        transition: all 0.2s ease;
    }

        .tech-logo-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 0px #000000;
            background-color: #f3f0ff;
        }

        .tech-logo-box img {
            max-width: 100%;
            max-height: 42px;
            object-fit: contain;
        }

    /* --- FLOATING COMMUNICATION STACK (Left Side) --- */
    .floating-contact-stack {
        position: fixed;
        bottom: 30px;
        left: 30px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        z-index: 9999;
    }

    .contact-floating-btn {
        width: 60px;
        height: 60px;
        color: #ffffff !important;
        border: 2px solid #000000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.9rem;
        box-shadow: 3px 3px 0px #000000;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .contact-floating-btn:hover {
            transform: translate(1px, 1px);
            box-shadow: 1px 1px 0px #000000;
        }

    .btn-brand-whatsapp {
        background-color: #25D366;
    }

        .btn-brand-whatsapp:hover {
            background-color: #20ba5a;
        }

    .btn-brand-messenger {
        background-color: #0084FF;
    }

        .btn-brand-messenger:hover {
            background-color: #0076e4;
        }

    .btn-brand-gmail {
        background-color: #EA4335;
    }

        .btn-brand-gmail:hover {
            background-color: #d63b2e;
        }

    /* --- GLOBAL FLOATING CODE BOX DESIGN (Right Side) --- */
    .global-floating-code {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 280px;
        background: rgba(30, 41, 59, 0.95);
        border: 2px solid #000000;
        border-radius: 12px;
        box-shadow: 5px 5px 0px #000000;
        font-family: 'Courier New', Courier, monospace;
        z-index: 9999;
        overflow: hidden;
        animation: floatingWindow 5s ease-in-out infinite;
    }

    .code-header-bar {
        background: #1e1e2e;
        padding: 8px 12px;
        display: flex;
        align-items: center;
        border-bottom: 2px solid #000000;
    }

        .code-header-bar .window-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 6px;
            display: inline-block;
        }

    .window-dot.r {
        background: #ff5f56;
    }

    .window-dot.y {
        background: #ffbd2e;
    }

    .window-dot.g {
        background: #27c93f;
    }

    .code-bar-title {
        color: #94a3b8;
        font-size: 0.75rem;
        margin-left: auto;
        font-weight: bold;
    }

    .code-body-area {
        padding: 12px 15px;
        font-size: 0.8rem;
        line-height: 1.4;
    }

        .code-body-area pre {
            margin: 0;
            color: #f8f8f2;
            white-space: pre-wrap;
        }

        .code-body-area .kw {
            color: #ff79c6;
            font-weight: bold;
        }

        .code-body-area .str {
            color: #f1fa8c;
        }

        .code-body-area .cmt {
            color: #6272a4;
            font-style: italic;
        }

    /* Smooth Floating Keyframe Animation (Maximized -45px Range) */
    @@keyframes floatingWindow {
        0% {
            transform: translateY(0px) rotate(-1deg);
        }

        50% {
            transform: translateY(-45px) rotate(4deg);
        }

        100% {
            transform: translateY(0px) rotate(-1deg);
        }
    }

    /* --- SYSTEM SCROLLBAR MANAGEMENT & UTILITIES --- */
    #certificationsSlider::-webkit-scrollbar,
    #projectSlider::-webkit-scrollbar,
    #featuredGallery::-webkit-scrollbar {
        display: none;
    }

    .scroll-smooth {
        scroll-behavior: smooth;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .gallery-nav-btn {
        position: absolute;
        top: 55%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #ffffff;
        border: 1.5px solid #000000;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .gallery-nav-btn:hover {
            background-color: #f3f0ff;
            transform: translateY(-50%) scale(1.05);
        }

    .prev-btn {
        left: 15px;
    }

    .next-btn {
        right: 15px;
    }

    .achievement-list-item {
        background-color: #ffffff;
        border: 2px solid #000000;
        border-radius: 12px;
        transition: background-color 0.2s ease, transform 0.2s ease;
    }

        .achievement-list-item:hover {
            background-color: #f8f6ff;
            transform: scale(1.01);
        }
</style>




