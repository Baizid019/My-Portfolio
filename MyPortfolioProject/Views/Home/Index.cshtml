@{
    ViewData["Title"] = "Home - Portfolio";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        --dark-bg: #0f172a;
        --card-bg: rgba(30, 41, 59, 0.7);
        --border-color: rgba(255, 255, 255, 0.1);
    }

    body {
        background-color: var(--dark-bg);
        color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
    }

    /* Glow Text Gradient */
    .text-gradient {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Premium Glassmorphism Cards */
    .glass-card {
        background: var(--card-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        transition: all 0.3s ease-in-out;
    }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
            border-color: rgba(99, 102, 241, 0.4);
        }

    /* Modern Profile Image Frame */
    .profile-img-container {
        position: relative;
        width: 320px;
        height: 320px;
        margin: 0 auto;
    }

        .profile-img-container::before {
            content: '';
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            background: var(--primary-gradient);
            border-radius: 50%;
            z-index: -1;
            filter: blur(8px);
            opacity: 0.8;
        }

    .profile-img-wrapper {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid var(--dark-bg);
    }

        .profile-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Custom Badges */
    .badge-custom {
        background: rgba(99, 102, 241, 0.15);
        color: #a5b4fc;
        border: 1px solid rgba(99, 102, 241, 0.3);
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* Sleek buttons */
    .btn-gradient {
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .btn-gradient:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
        }

    .btn-outline-custom {
        color: #f1f5f9;
        border: 1px solid var(--border-color);
        background: rgba(255, 255, 255, 0.05);
        transition: all 0.2s ease;
    }

        .btn-outline-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border-color: #a855f7;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet" />

<div class="container py-5 my-5">
    <div class="row align-items-center gy-5">
        <div class="col-lg-6 text-center text-lg-start">
            <div class="d-inline-flex mb-3">
                <span class="badge-custom">
                    <i class="bi bi-laptop me-2"></i> Full Stack Developer
                </span>
            </div>
            <h1 class="display-3 fw-extrabold mb-4" style="font-weight: 800;">
                Hi, I'm <span class="text-gradient">John Doe</span>
            </h1>
            <p class="lead text-muted fs-4 mb-5" style="max-width: 500px; line-height: 1.6;">
                I craft scalable web applications, robust APIs, and clean user interfaces using modern backend and frontend technologies.
            </p>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                <a class="btn btn-gradient btn-lg px-4 py-3 fw-bold" asp-controller="Home" asp-action="Resume">
                    Explore Resume <i class="bi bi-arrow-right ms-2"></i>
                </a>
                <a class="btn btn-outline-custom btn-lg px-4 py-3 fw-bold" asp-controller="Home" asp-action="DownloadCV">
                    Download CV <i class="bi bi-download ms-2"></i>
                </a>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="profile-img-container">
                <div class="profile-img-wrapper">
                    <img src="~/assets/profile.png" alt="Profile Picture" onerror="this.src='https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?fit=crop&w=500&h=500'" />
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5">
        <div class="col-12">
            <div class="glass-card p-5">
                <div class="row align-items-center">
                    <div class="col-md-3 mb-4 mb-md-0 text-center text-md-start">
                        <h2 class="fw-bold mb-0">About <span class="text-gradient">Me</span></h2>
                    </div>
                    <div class="col-md-9 border-start border-secondary ps-md-4">
                        <p class="lead text-muted mb-0" style="line-height: 1.8;">
                            A passionate developer with a strong foundation in MVC architecture, database systems, and UI components. I thrive on translating complex problems into beautiful, intuitive, and highly performant digital tools.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-4">
        <div class="col-12 text-center mb-5">
            <h3 class="fw-bold fs-2">Beyond the <span class="text-gradient">Code</span></h3>
            <p class="text-muted">What I spend my time on when I am not typing syntax</p>
        </div>

        <div class="col-md-6 mb-4">
            <div class="glass-card p-4 h-100 d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-3 rounded-3 bg-primary bg-opacity-10 text-primary me-3">
                        <i class="bi bi-people-fill fs-3 text-gradient"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Tech Community Mentor</h5>
                </div>
                <p class="text-muted flex-grow-1">
                    Guided over 50+ freshman students on data structures, basic algorithms, and setting up their first ASP.NET environments.
                </p>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="glass-card p-4 h-100 d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-3 rounded-3 bg-primary bg-opacity-10 text-primary me-3">
                        <i class="bi bi-trophy-fill fs-3 text-gradient"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Open Source Contributor</h5>
                </div>
                <p class="text-muted flex-grow-1">
                    Actively maintaining utility scripts and contributing styling improvements to public developer toolkits.
                </p>
            </div>
        </div>
    </div>
</div>