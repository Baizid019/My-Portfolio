<style>
    /* Main Portfolio Card Styling */
    .portfolio-card {
        background: #ffffff;
        border: 2px solid #000000;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .portfolio-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(124, 58, 237, 0.12);
        }

    /* Hero Profile Image Styling */
    .profile-img-container {
        position: relative;
        width: 300px;
        height: 300px;
        margin: 0 auto;
    }

        .profile-img-container::before {
            content: '';
            position: absolute;
            top: -8px;
            left: -8px;
            right: -8px;
            bottom: -8px;
            background: var(--primary-gradient);
            border-radius: 50%;
            z-index: -1;
            filter: blur(4px);
        }

    .profile-img-wrapper {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #000000;
    }

        .profile-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Custom Accent Badge */
    .badge-custom {
        background: rgba(124, 58, 237, 0.08);
        color: #7c3aed;
        border: 1.5px solid #000000;
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    /* Standard Interactive Pills for Skills */
    .skill-pill {
        background-color: #ffffff;
        border: 1.5px solid #000000;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e293b;
        display: inline-block;
        transition: all 0.2s ease;
    }

        .skill-pill:hover {
            background: var(--primary-gradient);
            color: #ffffff !important;
            border-color: #7c3aed;
            transform: scale(1.05);
        }

    /* Sub-card within Skills for Categorization */
    .skill-category-card {
        background: #fafafa;
        border: 1.5px solid #000000;
        border-radius: 16px;
        padding: 20px;
        height: 100%;
    }

    /* Timeline Structure for Experience & Education */
    .timeline-item {
        border-left: 3px solid #000000;
        padding-left: 24px;
        position: relative;
    }

        .timeline-item::before {
            content: '';
            position: absolute;
            width: 15px;
            height: 15px;
            background: #7c3aed;
            border: 2px solid #000000;
            border-radius: 50%;
            left: -9px;
            top: 14px;
        }

    /* Beautiful Light Download/Action Button with Black Border Shadow */
    .btn-download-custom {
        background-color: #f3f0ff;
        color: #7c3aed;
        border: 2.5px solid #000000;
        border-radius: 14px;
        font-weight: 800;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 0px #000000;
        transition: all 0.2s ease;
    }

        .btn-download-custom:hover {
            background-color: #e8e3ff;
            color: #6d28d9;
            transform: translateY(-2px);
            box-shadow: 0 6px 0px #000000;
        }

        .btn-download-custom:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0px #000000;
        }

    .section-title {
        font-weight: 800;
        color: #000000;
    }

    /* Institution & School Logos Wrapper */
    .institution-logo-container {
        width: 50px;
        height: 50px;
        min-width: 50px;
        border: 2px solid #000000;
        border-radius: 12px;
        overflow: hidden;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .institution-logo-container img {
            width: 85%;
            height: 85%;
            object-fit: contain;
        }

    /* Interactive Grid Boxes (For Platforms & Tech Logos) */
    .tech-logo-box {
        border: 2px solid #000000;
        border-radius: 14px;
        background-color: #ffffff;
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100px;
        box-shadow: 0 4px 0px #000000;
        transition: all 0.2s ease;
    }

        .tech-logo-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 0px #000000;
            background-color: #f3f0ff;
        }

        .tech-logo-box img {
            max-width: 100%;
            max-height: 42px;
            object-fit: contain;
        }

    /* --- Featured Photos Gallery Specific CSS --- */
    #featuredGallery::-webkit-scrollbar {
        display: none; /* Hide scrollbar for Chrome, Safari and Opera */
    }

    .scroll-smooth {
        scroll-behavior: smooth;
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
    }

    /* Floating Navigation Arrows */
    .gallery-nav-btn {
        position: absolute;
        top: 55%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #ffffff;
        border: 1.5px solid #000000;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .gallery-nav-btn:hover {
            background-color: #f3f0ff;
            transform: translateY(-50%) scale(1.05);
        }

    .prev-btn {
        left: 15px;
    }

    .next-btn {
        right: 15px;
    }
</style>


