@section Scripts {
    <script>
        function scrollGallery(scrollOffset) {
            const gallery = document.getElementById('featuredGallery');
            if (gallery) {
                gallery.scrollBy({
                    left: scrollOffset,
                    behavior: 'smooth'
                });
            }
        }

        function scrollProjects(direction) {
            const projectSlider = document.getElementById('projectSlider');
            if (projectSlider) {
                // Target the flex-shrink-0 class to get the exact layout width of the card item
                const firstCard = projectSlider.querySelector('.flex-shrink-0');
                if (firstCard) {
                    const cardWidth = firstCard.offsetWidth;
                    // Multiply card width by direction (1 for right, -1 for left)
                    projectSlider.scrollBy({
                        left: cardWidth * direction,
                        behavior: 'smooth'
                    });
                } else {
                    // Fallback default step if card structure changes
                    projectSlider.scrollBy({
                        left: 360 * direction,
                        behavior: 'smooth'
                    });
                }
            }
        }

        function scrollCertifications(direction) {
            const slider = document.getElementById('certificationsSlider');
            if (slider) {
                // Target individual card wrapper element to calculate dynamic step matching your width
                const firstCard = slider.querySelector('.item-card-wrapper');
                if (firstCard) {
                    const cardWidth = firstCard.offsetWidth;
                    slider.scrollBy({
                        left: cardWidth * direction,
                        behavior: 'smooth'
                    });
                } else {
                    // Fallback default step if card structure changes
                    slider.scrollBy({
                        left: 340 * direction,
                        behavior: 'smooth'
                    });
                }
            }
        }
    </script>
}


