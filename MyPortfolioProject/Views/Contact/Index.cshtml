@model MyPortfolioProject.Models.ContactMessage
@{
    ViewData["Title"] = "Ask Me Anything";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
        --light-bg: #f8fafc; /* Soft light background */
        --card-bg: #ffffff; /* Pure white card container */
        --input-bg: #ffffff; /* White input background */
        --input-border: #1e293b; /* Slate-800 thin border for inputs */
        --text-main: #1e293b; /* Slate-800 text */
        --text-muted: #475569; /* Slate-600 muted text */
        --input-focus-glow: rgba(124, 58, 237, 0.1);
    }

    body {
        background-color: var(--light-bg);
        color: var(--text-main);
        font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
    }

    /* Glow Text Gradient */
    .text-gradient {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Card with a Clean Black Border */
    .glass-card {
        background: var(--card-bg);
        border: 2px solid #000000; /* Crisp solid black border */
        border-radius: 20px;
        box-shadow: 0 15px 45px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .glass-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
        }

    /* Form Inputs with Defined Borders */
    .form-floating > .form-control {
        background-color: var(--input-bg) !important;
        border: 1.5px solid var(--input-border); /* Defined input border */
        color: var(--text-main) !important;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .form-floating > .form-control:focus {
            border-color: #7c3aed; /* Purple highlights on focus */
            box-shadow: 0 0 0 4px var(--input-focus-glow);
        }

    /* Floating Labels Styling */
    .form-floating > label {
        color: var(--text-muted) !important;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #7c3aed !important;
    }

    /* Icon Circle Container with a Thin Black Outline */
    .icon-box {
        width: 65px;
        height: 65px;
        background: rgba(124, 58, 237, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 25px;
        border: 1.5px solid #000000; /* Clean matching black outline */
    }

        .icon-box i {
            font-size: 1.8rem;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    /* Primary Submit Button with a Thin Black Bottom Shadow/Border */
    .btn-gradient {
        background: var(--primary-gradient);
        color: #fff;
        border: 1.5px solid #000000; /* Sharp border on button */
        border-radius: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

        .btn-gradient:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3);
        }

    /* Validation Errors */
    .field-validation-error {
        font-size: 0.85rem;
        color: #ef4444 !important;
        display: block;
        margin-top: 5px;
        text-align: left;
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet" />

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7 text-center">

            <div class="glass-card p-5 mt-4">

                <div class="icon-box">
                    <i class="bi bi-chat-left-text"></i>
                </div>

                <h1 class="fw-extrabold display-5 mb-3" style="font-weight: 800; color: #000000;">
                    Ask a <span class="text-gradient">Question</span>
                </h1>
                <p class="text-muted fs-5 mb-5">
                    Have a technical query or want to connect? Let me know below!
                </p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success border-2 border-success bg-success bg-opacity-10 text-success p-3 rounded-3 mb-4 text-start">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <form asp-controller="Contact" asp-action="Ask" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-4">
                        <input class="form-control" asp-for="Name" placeholder="Full Name" autocomplete="off" />
                        <label asp-for="Name">Full Name</label>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input class="form-control" asp-for="Email" type="email" placeholder="name@example.com" autocomplete="off" />
                        <label asp-for="Email">Email address</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-5">
                        <textarea class="form-control" asp-for="Question" placeholder="Write your question..." style="height: 12rem"></textarea>
                        <label asp-for="Question">Your Question</label>
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-gradient btn-lg py-3 fs-5" type="submit">
                            Send Message <i class="bi bi-send ms-2"></i>
                        </button>
                    </div>
                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}